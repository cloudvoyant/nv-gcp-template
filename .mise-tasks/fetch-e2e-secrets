#!/usr/bin/env bash
#MISE description="Pull E2E test credentials from GCP Secret Manager into .env.e2e.local"
set -euo pipefail
source "$(dirname "$0")/utils.sh"

log_info "Fetching E2E secrets from Secret Manager..."

# Inline body of scripts/fetch-e2e-secrets.sh
: "${GCP_DEVOPS_PROJECT_ID:?GCP_DEVOPS_PROJECT_ID is required}"
: "${PROJECT:?PROJECT is required}"

OUTPUT="apps/web/.env.e2e.local"
SECRET_NAME="${PROJECT}-e2e-secrets"

echo "# Generated by mise run fetch-e2e-secrets — DO NOT COMMIT" > "${OUTPUT}"
gcloud secrets versions access latest \
  --secret="${SECRET_NAME}" \
  --project="${GCP_DEVOPS_PROJECT_ID}" \
  >> "${OUTPUT}"

log_success "Credentials written to apps/web/.env.e2e.local"
